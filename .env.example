# ----------------------------------------------------------------------
#  Shop Route Optimizer — Environment Variables
#  Copy this file to .env and fill in your real keys.
#  NEVER commit the real .env file to version control.
# ----------------------------------------------------------------------

# Yandex Maps JS API key  (for the interactive map in the browser)
# Get it at: https://developer.tech.yandex.ru/  -> "JavaScript API and HTTP Geocoder"
YANDEX_MAPS_JS_KEY=your_js_api_key_here

# Yandex Geocoder / HTTP API key  (for backend shop search)
# Same key as above — one key covers both Geocoder HTTP and JS API on the free plan
YANDEX_GEOCODER_KEY=your_geocoder_key_here

# Flask settings
FLASK_DEBUG=false
PORT=5000